{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "outDir": "dist",
    "target": "ES2020"
  },
  "include": ["vite.config.ts", "src/main/**/*", "src/preload/**/*", "src/database/**/*"]
}
